# npm dependencies (TF.js etc.) — bundled into content/toxic-model.bundle.js,
# never shipped loose. Run `npm install` to recreate.
node_modules/

# Chrome-generated build output. Created automatically when the unpacked
# extension is loaded (it indexes the declarativeNetRequest rulesets). Never
# hand-edited, always regenerated — should not be in the repo.
_metadata/

# Local tooling / editor state (Claude Code, uploads scratch) — machine-specific.
.claude/
.uploads/

# Internal build/planning prompts — working notes, kept locally, not published.
sieve-phases.md
sieve-phase2-prompt.md
sieve-phase3-prompt.md
sieve-phase4-prompt.md
sieve-financial-protection-prompt.md

# esbuild's own metafile / logs, if ever emitted
*.log

# Packaged extension builds produced by build-chrome.ps1 / build-firefox.ps1
dist/

# Packaged extension artifacts / signing keys — never commit these
*.zip
*.crx
*.pem

# OS cruft
.DS_Store
Thumbs.db
